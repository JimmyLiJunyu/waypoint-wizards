// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  
}

model User {
  id Int @id @default(autoincrement()) // universal unique identifier
  email String @unique
  password String // hashed password
  name String?
  imageUrl String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // relation to join table
  itinearies Collaborator[]
}

model Destination {
  id Int @id @default(autoincrement())
  placeName String
  arrival DateTime
  departure DateTime
  position Float

  // relation
  itineraryId Int
  itinerary Itinerary @relation(fields: [itineraryId], references: [id], onDelete: Cascade)
}

model Itinerary {
  id Int @id @default(autoincrement())
  title String
  createdAt DateTime

  // relations
  destinations Destination[] // one to many
  collaborators Collaborator[]
}

// join table of user and itinerary, many to many relation
model Collaborator {
  id Int @id @default(autoincrement())
  role String @default("EDITOR") // can be owner, viewer etc

  // relations
  userId Int
  user User @relation(fields: [userId], references: [id])

  itineraryId Int
  itinerary Itinerary @relation(fields:[itineraryId], references:[id])

  @@unique([userId, itineraryId]) // Composite primary key of userId and itineraryId
}
